<mujoco model="fr3 pick and place">
  <compiler angle="radian"/>

  <option timestep="0.002">
		<flag warmstart="enable"></flag>
	</option>

  <!-- First, include all necessary assets and actuators -->
  <include file="fr3/assets.xml"/>

  <keyframe>
    <key name="home" qpos="0 0.3 0 -2.2 0 2.5 0.774 0.04 0.04 0 0 0 0 0 0 0"/>
  </keyframe>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <statistic center="0.2 0 1.0" extent=".8"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="1 1 1" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <equality>
    <weld body1="mocap" body2="eef_center" solimp="0.9 0.95 0.001" solref="0.02 1" relpose="0 0 0 1.0 0 0 0"></weld>
  </equality>
 
  <contact>
      <exclude body1="left_finger" body2="right_finger"></exclude>
  </contact>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body mocap="true" name="mocap" pos="0 0 0">
      <geom conaffinity="0" contype="0" pos="0 0 0" rgba="0 0.5 0 0.7" size="0.005 0.005 0.005" type="box"/>
    </body>

    <!-- Table -->
    <body pos="0 0 0">
      <geom name="table" type="box" pos="0 0 0.25" size="0.25 0.35 0.25" rgba="0.93 0.93 0.93 1"/>
    </body>

    <!-- Franka -->
    <body pos="-0.5 0 0.5">
      <include file="fr3/fr3.xml"/>
    </body>
    
    <body pos="-0.55 0 0.25">
      <geom name="franka_table" type="box" pos="0 0 0" size="0.15 0.15 0.25" rgba="0.93 0.93 0.93 1"/>
    </body>

    <!-- Cube -->
    <body name="cube" pos="0 0 0.525">
      <joint type="free" damping="0.01"/>
      <geom name="cube" type="box" size="0.025 0.025 0.025" rgba="0 0 0 1" condim="3" mass="0.1"/>
      <site name="cube_x" type="box" pos="0.03 0 0" size="0.03 0.003 0.003" rgba="1 0 0 0.5" group="1"/>
      <site name="cube_y" type="box" pos="0 0.03 0" size="0.003 0.03 0.003" rgba="0 1 0 0.5" group="1"/>
      <site name="cube_z" type="box" pos="0 0 0.03" size="0.003 0.003 0.03" rgba="0 0 1 0.5" group="1"/>
    </body>

    <body name="goal_frame" pos="0 0 0">
      <site name="goal_x" type="box" pos="0.03 0 0" size="0.03 0.003 0.003" rgba="1 0 0 0.5" group="1"/>
      <site name="goal_y" type="box" pos="0 0.03 0" size="0.003 0.03 0.003" rgba="0 1 0 0.5" group="1"/>
      <site name="goal_z" type="box" pos="0 0 0.03" size="0.003 0.003 0.03" rgba="0 0 1 0.5" group="1"/>
    </body>

    <body name="goal" pos="0 0 0">
      <site name="goal" type="sphere" size="0.02" rgba="0 1 0 0.5" group="1"/>
    </body>

  </worldbody>

	<actuator>
		<position ctrllimited="true" ctrlrange="0 0.2" joint="finger:left_joint" kp="30000" name="finger:left_joint" user="1"></position>
		<position ctrllimited="true" ctrlrange="0 0.2" joint="finger:right_joint" kp="30000" name="finger:right_joint" user="1"></position>
	</actuator>

</mujoco>
